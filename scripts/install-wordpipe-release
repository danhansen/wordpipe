#!/usr/bin/env sh
set -eu

REPO="${WORDPIPE_GITHUB_REPO:-danhansen/wordpipe}"
VERSION="${WORDPIPE_VERSION:-latest}"
ARCH="$(uname -m)"
UUID="wordpipe@dhansen.dev"
SERVICE_NAME="dev.wordpipe.Service"
ARCHIVE_NAME="wordpipe-linux-${ARCH}.tar.gz"

FROM_EXTRACTED=""

usage() {
  cat <<'EOF'
Usage: install-wordpipe-release [--from-extracted DIR]

Install Wordpipe's GNOME Shell extension plus the Rust D-Bus service into the
current user account. By default this downloads the latest GitHub Release
archive from $WORDPIPE_GITHUB_REPO.

Environment:
  WORDPIPE_GITHUB_REPO       GitHub repo, default danhansen/wordpipe
  WORDPIPE_VERSION           Release tag, default latest
  WORDPIPE_SKIP_PYTHON_DEPS  Set to 1 to skip model-installer venv setup
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --from-extracted)
      FROM_EXTRACTED="${2:?missing --from-extracted value}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

need_tool() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "wordpipe install error: missing required tool: $1" >&2
    exit 1
  fi
}

download_release() {
  need_tool curl
  need_tool tar

  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/wordpipe-install.XXXXXX")"
  archive="$tmp_dir/$ARCHIVE_NAME"
  checksum="$archive.sha256"

  if [ "$VERSION" = "latest" ]; then
    base_url="https://github.com/$REPO/releases/latest/download"
  else
    base_url="https://github.com/$REPO/releases/download/$VERSION"
  fi

  echo "Downloading $base_url/$ARCHIVE_NAME" >&2
  curl -fsSL "$base_url/$ARCHIVE_NAME" -o "$archive"
  if curl -fsSL "$base_url/$ARCHIVE_NAME.sha256" -o "$checksum"; then
    if command -v sha256sum >/dev/null 2>&1; then
      (cd "$tmp_dir" && sha256sum -c "$(basename "$checksum")") >&2
    else
      echo "sha256sum not available; skipping checksum verification" >&2
    fi
  else
    echo "checksum not available; continuing without verification" >&2
  fi

  mkdir -p "$tmp_dir/extract"
  tar -xzf "$archive" -C "$tmp_dir/extract"
  find "$tmp_dir/extract" -mindepth 1 -maxdepth 1 -type d | head -n 1
}

if [ -n "$FROM_EXTRACTED" ]; then
  PACKAGE_DIR="$FROM_EXTRACTED"
else
  PACKAGE_DIR="$(download_release)"
fi

if [ ! -x "$PACKAGE_DIR/bin/wordpipe-service" ]; then
  echo "wordpipe install error: invalid package directory: $PACKAGE_DIR" >&2
  exit 1
fi

DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
LIBEXEC_DIR="$HOME/.local/libexec/wordpipe"
EXTENSION_DIR="$DATA_HOME/gnome-shell/extensions/$UUID"
DBUS_SERVICE_DIR="$DATA_HOME/dbus-1/services"
SYSTEMD_USER_DIR="$CONFIG_HOME/systemd/user"

echo "Installing Wordpipe binaries"
mkdir -p "$LIBEXEC_DIR"
rm -rf "$LIBEXEC_DIR/bin" "$LIBEXEC_DIR/lib" "$LIBEXEC_DIR/share"
cp -a "$PACKAGE_DIR/bin" "$LIBEXEC_DIR/bin"
cp -a "$PACKAGE_DIR/lib" "$LIBEXEC_DIR/lib"
cp -a "$PACKAGE_DIR/share" "$LIBEXEC_DIR/share"

if [ "${WORDPIPE_SKIP_PYTHON_DEPS:-0}" != "1" ]; then
  need_tool python3
  echo "Installing model-download/conversion Python environment"
  python3 -m venv "$LIBEXEC_DIR/python-venv"
  "$LIBEXEC_DIR/python-venv/bin/python" -m pip install --upgrade pip
  "$LIBEXEC_DIR/python-venv/bin/python" -m pip install \
    -r "$LIBEXEC_DIR/share/wordpipe/requirements-model-install.txt"
else
  echo "Skipping Python dependency setup because WORDPIPE_SKIP_PYTHON_DEPS=1"
fi

echo "Installing D-Bus activation service"
mkdir -p "$DBUS_SERVICE_DIR"
sed "s|@WORDPIPE_LIBEXEC@|$LIBEXEC_DIR|g" \
  "$PACKAGE_DIR/share/dbus-1/services/$SERVICE_NAME.service" \
  > "$DBUS_SERVICE_DIR/$SERVICE_NAME.service"

echo "Installing systemd user unit"
mkdir -p "$SYSTEMD_USER_DIR"
sed "s|@WORDPIPE_LIBEXEC@|$LIBEXEC_DIR|g" \
  "$PACKAGE_DIR/share/systemd/user/wordpipe-service.service" \
  > "$SYSTEMD_USER_DIR/wordpipe-service.service"
if command -v systemctl >/dev/null 2>&1; then
  systemctl --user daemon-reload || true
  systemctl --user try-restart wordpipe-service.service || true
fi

echo "Installing GNOME Shell extension"
tmp_extension="${EXTENSION_DIR}.tmp.$$"
rm -rf "$tmp_extension"
mkdir -p "$(dirname "$EXTENSION_DIR")"
cp -a "$PACKAGE_DIR/share/gnome-shell/extensions/$UUID" "$tmp_extension"
if command -v glib-compile-schemas >/dev/null 2>&1; then
  glib-compile-schemas "$tmp_extension/schemas"
fi
rm -rf "$EXTENSION_DIR"
mv "$tmp_extension" "$EXTENSION_DIR"

if command -v gnome-extensions >/dev/null 2>&1; then
  if gnome-extensions info "$UUID" >/dev/null 2>&1; then
    gnome-extensions enable "$UUID" || true
  else
    echo "GNOME Shell has not discovered $UUID yet; log out and back in, then enable it."
  fi
fi

echo "Installed Wordpipe"
echo "Open settings with: gnome-extensions prefs $UUID"
echo "Install a model with: $LIBEXEC_DIR/bin/wordpipe-model-install --profile compact"
