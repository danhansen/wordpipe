#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UUID="wordpipe@dhansen.dev"
SERVICE_NAME="dev.wordpipe.Service"

PREFIX="${XDG_DATA_HOME:-$HOME/.local/share}"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
BIN_DIR="$HOME/.local/libexec/wordpipe"
EXTENSION_DIR="$PREFIX/gnome-shell/extensions/$UUID"
DBUS_SERVICE_DIR="$PREFIX/dbus-1/services"
SYSTEMD_USER_DIR="$CONFIG_HOME/systemd/user"

echo "Building wordpipe-service"
cargo build --release -p wordpipe-service --manifest-path "$ROOT/Cargo.toml"

echo "Installing service binary"
install -d "$BIN_DIR"
install -m 0755 "$ROOT/target/release/wordpipe-service" "$BIN_DIR/wordpipe-service"

echo "Installing D-Bus activation service"
install -d "$DBUS_SERVICE_DIR"
cat > "$DBUS_SERVICE_DIR/$SERVICE_NAME.service" <<EOF
[D-BUS Service]
Name=$SERVICE_NAME
Exec=$BIN_DIR/wordpipe-service
EOF

echo "Installing systemd user unit"
install -d "$SYSTEMD_USER_DIR"
install -m 0644 "$ROOT/packaging/systemd/wordpipe-service.service" \
    "$SYSTEMD_USER_DIR/wordpipe-service.service"
systemctl --user daemon-reload

echo "Installing GNOME Shell extension"
install -d "$EXTENSION_DIR"
rsync -a --delete \
    --exclude 'schemas/gschemas.compiled' \
    "$ROOT/extensions/gnome-shell/$UUID/" \
    "$EXTENSION_DIR/"
glib-compile-schemas "$EXTENSION_DIR/schemas"

echo "Enabling GNOME Shell extension"
gnome-extensions enable "$UUID" || true

echo "Installed $UUID"
echo "Restart GNOME Shell or log out/in if the extension is not visible yet."
echo "Run preferences with: gnome-extensions prefs $UUID"
